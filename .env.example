# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=helm
POSTGRES_USER=helm
POSTGRES_PASSWORD=change-me-secure-password

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Helm
APP_ENV=production
APP_SECRET_KEY=change-me-32-chars-random-string!
APP_URL=https://your-domain.com

# Host names match Docker Compose service names
DB_URL=postgresql+asyncpg://helm:change-me-secure-password@postgres:5432/helm
REDIS_URL=redis://redis:6379/0

# ── EVE Online SSO ────────────────────────────────────────────────────────────
# Register at https://developers.eveonline.com
EVE_CLIENT_ID=your_eve_client_id
EVE_CLIENT_SECRET=your_eve_client_secret
EVE_CALLBACK_URL=https://your-domain.com/auth/eve/callback

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-random!
JWT_ACCESS_TOKEN_EXPIRE=900
JWT_REFRESH_TOKEN_EXPIRE=2592000

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Tuning (optional) ─────────────────────────────────────────────────────────
# HTTP_PORT=80
# UVICORN_WORKERS=4
# CELERY_CONCURRENCY=4
