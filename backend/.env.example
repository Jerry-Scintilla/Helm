# ── 应用基础 ──────────────────────────────
APP_NAME=Helm
APP_ENV=development
APP_SECRET_KEY=change-me-32-chars-random-string!
APP_URL=http://localhost:8000

# ── 数据库 ────────────────────────────────
DB_URL=postgresql+asyncpg://helm:helm@127.0.0.1:5432/helm

# ── Redis ─────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── EVE SSO（developers.eveonline.com 申请）
EVE_CLIENT_ID=your_eve_client_id
EVE_CLIENT_SECRET=your_eve_client_secret
EVE_CALLBACK_URL=http://localhost:8000/auth/eve/callback

# ── JWT ──────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-random!
JWT_ACCESS_TOKEN_EXPIRE=900
JWT_REFRESH_TOKEN_EXPIRE=2592000

# ── Celery ───────────────────────────────
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
